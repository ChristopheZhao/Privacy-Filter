{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://privacy-filter.local/model-findings.schema.json",
  "title": "Local LLM Filter Findings",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "anchor_text",
          "replacement",
          "confidence",
          "reason",
          "context_before",
          "context_after"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "anchor_text": {
            "type": "string",
            "minLength": 1
          },
          "replacement": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "context_before": {
            "type": "string"
          },
          "context_after": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
